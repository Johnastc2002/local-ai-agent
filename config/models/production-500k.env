# Qwen3.6-27B-FP8 on 1× H200 — native 262k context (vLLM-official, actually boots)
# Pod: MODEL_PROFILE=production-500k bash scripts/install-on-pod.sh
#
# 524288 + YaRN often OOMs on single H200 at engine init (KV prealloc).
# For 524k try: VLLM_USE_YARN=1 MAX_MODEL_LEN=524288 (may still OOM) or 2× H100 TP=2.

MODEL_NAME=Qwen/Qwen3.6-27B-FP8
MAX_MODEL_LEN=262144
GPU_MEMORY_UTILIZATION=0.92
TOOL_CALL_PARSER=qwen3_xml
ENABLE_AUTO_TOOL_CHOICE=true
REASONING_PARSER=qwen3

VLLM_KV_CACHE_DTYPE=fp8
VLLM_LANGUAGE_MODEL_ONLY=true
VLLM_ENFORCE_EAGER=true
VLLM_MIN_VERSION=0.17.0

# Set VLLM_USE_YARN=1 and MAX_MODEL_LEN=524288 to attempt YaRN ~524k (experimental on 1× H200)
VLLM_USE_YARN=0
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TENSOR_PARALLEL_SIZE=1

CURSOR_PLAN_MAX_ITERATIONS=2
REFINE_MAX_TOKENS=8192
REFINE_MAX_TOKENS_CAP=8192
REFINE_MEMORY_EVERY=10

SYSTEM_PREFIX_MAX_TOKENS=16384
MIN_TAIL_MESSAGES=64
ICR_MAX_CHARS=16000
