# Small model for pipeline testing (~6–8 GB VRAM; 32k context needs ~10–12 GB)
# Pod: bash scripts/install-on-pod.sh

MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
TOOL_CALL_PARSER=hermes
ENABLE_AUTO_TOOL_CHOICE=true

# Fast ICR smoke — increase for real plans
CURSOR_PLAN_MAX_ITERATIONS=1
REFINE_MAX_TOKENS=2048
