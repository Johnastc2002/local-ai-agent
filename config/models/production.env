# Production model (requires strong GPU, e.g. A100 40GB+)
# Use: MODEL_PROFILE=production bash scripts/install-on-pod.sh

MODEL_NAME=Qwen/Qwen3.6-27B
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
TOOL_CALL_PARSER=qwen3_xml
ENABLE_AUTO_TOOL_CHOICE=true
REASONING_PARSER=qwen3

CURSOR_PLAN_MAX_ITERATIONS=8
REFINE_MAX_TOKENS=8192
