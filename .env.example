# Copy to .env on Mac (required) and pod (optional — install script creates this):
#   cp .env.example .env

# --- Mac only (required) ---
RUNPOD_API_KEY=
RUNPOD_POD_ID=

# --- Mac + pod ---
RUNPOD_PORT=8000
GATEWAY_PORT=8787
MODEL_PROFILE=test

# Pod: ICR prompts clone path (install script creates if missing)
ICR_REPO_HOST=/workspace/Iterative-Contextual-Refinements

# Pod: your coding project (REQUIRED for ICR to read code like Opus)
CODEBASE_ROOT=/workspace/bobot-xs-v1
# Cursor Mac path → remapped to CODEBASE_ROOT on pod
CODEBASE_HOST_ROOT=/Users/tough/hobby/bobot-xs-v1
# Install script clones this if CODEBASE_ROOT is missing (set your repo URL)
CODEBASE_GIT_URL=

# ICR agents: read_file / grep / list_dir on CODEBASE_ROOT (auto when root exists)
REFINE_CODEBASE_TOOLS=auto

# Optional: faster HuggingFace downloads / gated models
HF_TOKEN=

# Gateway behavior (ICR_MODE=auto default)
#   auto/off — auto runs ICR on every user turn; off = passthrough (debug)
ICR_MODE=auto
