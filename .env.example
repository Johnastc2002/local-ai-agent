# Copy to .env and fill in secrets only:
#   cp .env.example .env

RUNPOD_API_KEY=
RUNPOD_POD_ID=

# Optional overrides (defaults work for most RunPod pods)
# RUNPOD_BASE_URL=
# GATEWAY_BASE_URL=
RUNPOD_PORT=8000
GATEWAY_PORT=8787

# Model profile: test (Qwen2.5-3B, weak GPU) | production (Qwen3.6-27B)
# Mac smoke tests merge config/models/${MODEL_PROFILE}.env automatically
MODEL_PROFILE=test

# On pod: path to ICR repo (install script clones if missing)
ICR_REPO_HOST=/workspace/Iterative-Contextual-Refinements

# Optional HuggingFace token (gated models / faster downloads)
HF_TOKEN=

# Gateway behavior
ICR_MODE=auto
